<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#0a0e14"/>
      <stop offset="100%" stop-color="#1f2937"/>
    </linearGradient>
    <linearGradient id="forge" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#f0a500"/>
      <stop offset="50%" stop-color="#ff6b00"/>
      <stop offset="100%" stop-color="#dc2626"/>
    </linearGradient>
  </defs>
  <!-- 圓角方形底 (maskable 安全區內) -->
  <rect width="512" height="512" rx="110" fill="url(#bg)"/>
  <!-- 中央內容圈 (避開 maskable 邊角裁切) -->
  <g transform="translate(256 256)">
    <!-- A 字形塊狀:Alpha 含義 -->
    <path d="M -90 80 L 0 -100 L 90 80 L 55 80 L 38 38 L -38 38 L -55 80 Z" 
          fill="url(#forge)" stroke="#fff" stroke-width="2" stroke-opacity="0.15"/>
    <!-- A 字內橫線 -->
    <rect x="-22" y="10" width="44" height="14" fill="#0a0e14" rx="2"/>
    <!-- 底部品牌標識線 -->
    <rect x="-60" y="100" width="120" height="3" fill="#f0a500" opacity="0.6" rx="1.5"/>
    <!-- PRO 字樣 -->
    <text x="0" y="125" text-anchor="middle" font-family="Arial Black, sans-serif" 
          font-size="20" font-weight="900" fill="#3bb8f5" letter-spacing="3">PRO</text>
  </g>
</svg>
